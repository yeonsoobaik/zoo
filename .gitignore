# Monorepo root safety net — each sub-project has its own .gitignore.
# These patterns guard against accidentally committing build artifacts
# from any package.

# dependencies
**/node_modules/

# next.js
**/.next/
**/out/

# build outputs
**/build/
**/dist/

# misc
**/.DS_Store
*.pem

# debug
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# env files
.env*.local
**/.env*.local

# vercel
**/.vercel

# typescript
**/*.tsbuildinfo
**/next-env.d.ts
